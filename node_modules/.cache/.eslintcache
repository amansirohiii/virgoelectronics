ingCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},{"filePath":"64","messages":"65","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},{"filePath":"66","messages":"67","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},{"filePath":"68","messages":"69","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"36"},"/home/amansirohi/Desktop/kashkart/src/index.js",[],["70","71"],"/home/amansirohi/Desktop/kashkart/src/App.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Cart.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Home.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Header.js",["72","73","74"],"import React, { useState, useContext } from 'react';\nimport { Link } from \"react-router-dom\";\nimport ShoppingCartIcon from '@material-ui/icons/ShoppingCart';\nimport { DataContext } from \"./DataProvider\";\n\nexport default function Header(props) {\n\n    const [menu, setMenu] = useState(false);\n    const value = useContext(DataContext);\n    const [cart] = value.cart;\n\n    const toggleMenu = () => {\n        setMenu(!menu);\n    }\n\n    const styles = {\n\n        largeIcon: {\n            width: 28,\n            height: 28\n        },\n\n        styleMenu: {\n            top: menu ? 0 : \"-100%\",\n            backgroundColor: \"#2b6777\"\n        }\n    };\n\n    const handleChange = event => {\n        props.setSearch(event.target.value);\n    };\n\n    return (\n        <header>\n            <div className=\"logo\">\n                <h1><Link to=\"/\">VIRGO ELECTRONICS</Link></h1>\n            </div>\n\n            \n\n            <ul style={styles.styleMenu}>\n                <li><Link to=\"/\">Home</Link></li>\n                <li><Link to=\"/products\">Products</Link></li>\n                <li onClick={toggleMenu}>\n                    <img src=\"cross.png\" alt=\"close-menu\" width=\"30\" className=\"menu\" />\n                </li>\n            </ul>\n\n\n            <div className=\"menu\" onClick={toggleMenu}>\n                <img src=\"menu.svg\" alt=\"menu\" width=\"30\" />\n            </div>\n\n        </header>\n    )\n}\n","/home/amansirohi/Desktop/kashkart/src/components/Products.js",["75"],"import React, { useContext } from 'react';\nimport { DataContext } from \"./DataProvider\";\nimport { Link } from \"react-router-dom\";\n\nexport default function Products(props) {\n\n    const value = useContext(DataContext);\n    const [products] = value.products;\n    const addCart = value.addCart;\n\n    return (\n        <section>\n            <div className=\"products\">\n                {\n                    products.filter(product => {\n                        if (product.title.toLowerCase().includes(props.search.toLowerCase())) {\n                            return product;\n                        }\n                        else {\n                            return false;\n                        }\n\n                    }).map(product => (\n                        <div className=\"products-card\" key={product.pid}>\n                            <Link to={`/products/${product.pid}`}>\n                                <img src={product.images[0]} alt=\"cover-pic\" />\n                            </Link>\n                            <div className=\"products-content\">\n                                <h3 title={product.title}>\n                                    <Link to={`/products/${product.pid}`}>{product.title}</Link>\n                                </h3>\n                                <p className=\"products-desc\">{product.description}</p>\n                                <p className=\"products-price\">&#8377; {product.price}</p>\n                            </div>\n                        </div>\n                    ))\n                }\n            </div>\n        </section>\n    )\n}\n","/home/amansirohi/Desktop/kashkart/src/components/DataProvider.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Footer.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Details/Details.js",["76","77"],"import React, { useState, useContext, useRef } from 'react';\nimport { useParams, Link } from \"react-router-dom\";\nimport { DataContext } from \"../DataProvider\";\nimport DetailsThumb from \"./DetailsThumb\";\nimport Colors from \"./Colors\";\n\nexport default function Details() {\n\n    const { id } = useParams();\n    const value = useContext(DataContext);\n    const [products] = value.products;\n    const addCart = value.addCart;\n    const [index, setIndex] = useState(0);\n    const imgDiv = useRef();\n\n    const details = products.filter((product) => {\n        return product.pid === id;\n    })\n\n    const handleMouseMove = (e) => {\n        const { left, top, width, height } = e.target.getBoundingClientRect();\n        const x = (e.pageX - left) / width * 100;\n        const y = (e.pageY - top) / height * 100;\n\n        imgDiv.current.style.backgroundPosition = `${x}% ${y}%`;\n    }\n\n    return (\n        <section>\n            {\n                details.map(product => (\n                    <div className=\"details\" key={product.pid}>\n                        <div className=\"details-img\" onMouseMove={handleMouseMove} style={{ backgroundImage: `url(${product.images[index]})` }} ref={imgDiv} onMouseLeave={() => imgDiv.current.style.backgroundPosition = `center`} />\n\n                        <div className=\"details-content\">\n                            <h2 title={product.title}>{product.title}</h2>\n                            <Colors colors={product.colors} />\n                            <p>{product.description}</p>\n                            <p>{product.content}</p>\n                            <DetailsThumb images={product.images} setIndex={setIndex} />\n                            <h3>&#8377; {product.price}</h3>\n                        </div>\n\n                    </div>\n                ))\n            }\n        </section>\n    )\n}\n","/home/amansirohi/Desktop/kashkart/src/components/Error.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Signup/Register.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Details/DetailsThumb.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Details/Colors.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Signup/useForm.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Signup/Validation.js",[],"/home/amansirohi/Desktop/kashkart/src/components/Signup/FormSuccess.js",[],{"ruleId":"78","replacedBy":"79"},{"ruleId":"80","replacedBy":"81"},{"ruleId":"82","severity":1,"message":"83","line":3,"column":8,"nodeType":"84","messageId":"85","endLine":3,"endColumn":24},{"ruleId":"82","severity":1,"message":"86","line":10,"column":12,"nodeType":"84","messageId":"85","endLine":10,"endColumn":16},{"ruleId":"82","severity":1,"message":"87","line":29,"column":11,"nodeType":"84","messageId":"85","endLine":29,"endColumn":23},{"ruleId":"82","severity":1,"message":"88","line":9,"column":11,"nodeType":"84","messageId":"85","endLine":9,"endColumn":18},{"ruleId":"82","severity":1,"message":"89","line":2,"column":21,"nodeType":"84","messageId":"85","endLine":2,"endColumn":25},{"ruleId":"82","severity":1,"message":"88","line":12,"column":11,"nodeType":"84","messageId":"85","endLine":12,"endColumn":18},"no-native-reassign",["90"],"no-negated-in-lhs",["91"],"no-unused-vars","'ShoppingCartIcon' is defined but never used.","Identifier","unusedVar","'cart' is assigned a value but never used.","'handleChange' is assigned a value but never used.","'addCart' is assigned a value but never used.","'Link' is defined but never used.","no-global-assign","no-unsafe-negation"]